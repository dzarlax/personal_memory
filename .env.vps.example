MEMORY_DOMAIN=example.com
EMBED_MODEL=intfloat/multilingual-e5-small

# Username stored as metadata in facts (any string, e.g. your name)
MEMORY_USER=your_username

# Todoist API token (get from https://app.todoist.com/app/settings/integrations/developer)
TODOIST_TOKEN=your_todoist_api_token

# Backup settings (memory-backup service)
COLLECTION=memory
KEEP_SNAPSHOTS=7          # number of snapshots to keep
BACKUP_INTERVAL_HOURS=24  # how often to create a snapshot

# Only needed if deploying Traefik via this compose file.
# Generate with: echo $(htpasswd -nB user) | sed -e s/\\$/\\$\\$/g
# TRAEFIK_AUTH_USERS=user:$$2y$$...
