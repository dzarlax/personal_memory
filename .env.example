MEMORY_DOMAIN=example.com
EMBED_MODEL=intfloat/multilingual-e5-small

# Username stored as metadata in facts (any string, e.g. your name)
MEMORY_USER=your_username

# Optional services (set to true to enable)
ENABLE_TODOIST=false
ENABLE_VIZ=false

# Todoist API token (only needed when ENABLE_TODOIST=true)
# Get from https://app.todoist.com/app/settings/integrations/developer
TODOIST_TOKEN=your_todoist_api_token

# Backup settings
KEEP_SNAPSHOTS=7          # number of snapshots to keep
BACKUP_INTERVAL_HOURS=24  # how often to create a snapshot

# RAG (hierarchical document search) — optional
ENABLE_RAG=false
RAG_DOCUMENTS_DIR=/root/documents/personal
RAG_CHUNK_MAX_BYTES=1500
RAG_FOLDER_TOP_K=3
RAG_FOLDER_THRESHOLD=0.50
RAG_COLLECTION_CHUNKS=doc_chunks
RAG_COLLECTION_FOLDERS=doc_folders
