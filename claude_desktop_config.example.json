{
  "mcpServers": {
    "personal-memory": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://mcp.yourdomain.com/memory",
        "--header",
        "Authorization:Bearer ${MEMORY_API_KEY}"
      ],
      "env": {
        "MEMORY_API_KEY": "your-api-key-here"
      }
    }
  }
}
